{
  "buildCommand": "pip install -r requirements.txt --quiet && python build_vercel.py",
  "framework": "django",
  "python": {
    "version": "3.11"
  },
  "env": {
    "DJANGO_SETTINGS_MODULE": "api.settings",
    "VERCEL_BUILD": "1",
    "PYTHONUNBUFFERED": "1"
  },
  "builds": [
    {
      "src": "manage.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1",
      "headers": {
        "Cache-Control": "public, max-age=3600, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "api/wsgi.py"
    }
  ]
}
